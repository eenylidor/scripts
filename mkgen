#!/usr/bin/env bash

if [ -z "$1" ]; then
    echo "Usage: mkgen <file_name.c>"
    exit 1
fi

SOURCE=$1
FILENAME="${SOURCE%.*}"

# 1. Generate the Makefile
cat << EOF > Makefile
build: build-arm build-x86 build-static-arm build-static-x86

build-arm:
	arm-linux-gnueabihf-gcc -O2 -Wall $SOURCE -o ${FILENAME}_arm

build-x86:
	gcc -O2 -Wall $SOURCE -o ${FILENAME}_x86

build-static-x86:
	gcc -O2 -Wall -static $SOURCE -o ${FILENAME}_static_x86

build-static-arm:
	arm-linux-gnueabihf-gcc -O2 -Wall -static $SOURCE -o ${FILENAME}_static_arm 

run-x86:
	./${FILENAME}_x86

run-arm:
	qemu-arm -L /usr/arm-linux-gnueabihf/ ./${FILENAME}_arm

run-static-arm:
	qemu-arm -L /usr/arm-linux-gnueabihf/ ./${FILENAME}_static_arm

run-static-x86:
	./${FILENAME}_static_x86

clean:
	rm -f ${FILENAME}_x86 ${FILENAME}_arm ${FILENAME}_static_arm ${FILENAME}_static_x86 README.md Makefile
EOF

# 2. Generate the README.md
cat << EOF > README.md
# Project: $FILENAME

This project contains cross-compiled binaries for x86 and ARM.

## Commands
* **\`make build\`**: Compiles the 4 versions.
* **\`make clean\`**: Deletes binaries, README, and the Makefile itself.

## Execution
* **x86**: \`make run-x86\`
* **ARM**: \`make run-arm\`
* **Static ARM**: \`make run-static-arm\`
* **Static x86**: \`make run-static-x86\`
---
*Generated by mkgen.*
EOF

echo "✅ Makefile and README.md generated. 'make clean' will now wipe the folder clean."